{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "jsx": "react-jsx",
    "allowJs": false,
    "skipLibCheck": true,
    "types": ["bun-types"],
    "noEmit": true
  },
  "include": [
    "electron/**/*.ts",
    "poller.ts",
    "scripts/**/*.ts",
    "src/**/*.ts",
    "studio/renderer/**/*.ts",
    "studio/renderer/**/*.tsx"
  ]
}
